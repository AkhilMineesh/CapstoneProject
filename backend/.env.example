# Default: run fully local without OpenAI.
# MEDRAG_EMBEDDINGS_PROVIDER=openai

# Mandatory: enable OpenAI embeddings.

MEDRAG_OPENAI_API_KEY="insert_your_openai_api_key_here"
MEDRAG_EMBEDDINGS_PROVIDER=openai
MEDRAG_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
MEDRAG_OPENAI_BASE_URL=https://api.openai.com/v1
# Optional: deeper clinical reasoning over retrieved evidence (used in insights summary).
MEDRAG_OPENAI_CLINICAL_REASONING=true
MEDRAG_OPENAI_REASONING_MODEL=gpt-4.1-mini
# MEDRAG_OPENAI_REASONING_TIMEOUT_S=30
# Optional multimodal extraction models (document/image via responses, audio via transcriptions).
# MEDRAG_OPENAI_MULTIMODAL_MODEL=gpt-4.1-mini
# MEDRAG_OPENAI_AUDIO_MODEL=gpt-4o-mini-transcribe

# Optional: LLM-based reranking (set to a chat-capable model name).
# MEDRAG_OPENAI_RERANK_MODEL=your_model_name_here

