# Default: run fully local without OpenAI.
MEDRAG_EMBEDDINGS_PROVIDER=hash

# Optional: enable OpenAI embeddings (explicit opt-in).
# MEDRAG_OPENAI_API_KEY=your_openai_api_key_here
# MEDRAG_EMBEDDINGS_PROVIDER=openai
# MEDRAG_OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional: LLM-based reranking (set to a chat-capable model name).
# MEDRAG_OPENAI_RERANK_MODEL=your_model_name_here
